{
  "name": "@dz/-",
  "version": "0.0.1",
  "description": "typescript utility library",
  "author": "Mitch Dzugan <mitchdzugan@gmail.com>",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "MIT",
  "homepage": "https://github.com/mitchdzugan/dz__DOLLAR_SIGN__.ts#readme",
  "bugs": {
    "url": "https://github.com/mitchdzugan/dz__DOLLAR_SIGN__.ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitchdzugan/dz__DOLLAR_SIGN__.ts.git"
  },
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./YoutubeClip": {
      "node": "./dist/YoutubeClip.mjs",
      "browser": "./dist/YoutubeClip.mjs",
      "types": "./dist/YoutubeClip.d.mts"
    },
    "./node": {
      "import": "./dist/node.mjs",
      "types": "./dist/node.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "format:check": "biome check --linter-enabled=false",
    "format:fix": "biome check --linter-enabled=false --write",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:coverage:json": "vitest --run --coverage --reporter=json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.4",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "tsdown": "^0.12.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "library",
    "starter",
    "template",
    "boilerplate",
    "tslib",
    "ts",
    "es6",
    "esm",
    "modern",
    "minimal"
  ],
  "dependencies": {
    "@slippi/slippi-js": "9.0.0",
    "@types/react": "^19.2.14",
    "@types/youtube-player": "^5.5.11",
    "classnames": "^2.5.1",
    "mutative": "^1.3.0",
    "re-resizable": "^6.11.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.6",
    "youtube-player": "^5.6.0"
  }
}
